# ── Helpers ───────────────────────────────────────────────────────────────────

def safe(val, fmt=None, na="N/A"):
    """Format a value safely, returning na string on None / NaN."""
    try:
        if val is None or (isinstance(val, float) and pd.isna(val)):
            return na
        if fmt == "pct":
            return f"{val * 100:.2f}%"
        if fmt == "pct_direct":
            return f"{val:.2f}%"
        if fmt == "B":
            return f"${val / 1e9:.2f}B"
        if fmt == "M":
            return f"${val / 1e6:.2f}M"
        if fmt == "price":
            return f"${val:,.2f}"
        if fmt == "int":
            return f"{int(val):,}"
        if fmt == "2f":
            return f"{val:.2f}"
        return str(val)
    except Exception:
        return na


def pct_change(start, end):
    """Return % change as a formatted string."""
    try:
        if start and end and start != 0:
            chg = (end - start) / abs(start) * 100
            sign = "+" if chg >= 0 else ""
            return f"{sign}{chg:.2f}%"
    except Exception:
        pass
    return "N/A"


def compute_rsi(prices, period=14):
    """Compute RSI from a pandas Series of closing prices."""
    delta = prices.diff()
    gain  = delta.clip(lower=0).rolling(period).mean()
    loss  = (-delta.clip(upper=0)).rolling(period).mean()
    rs    = gain / loss
    rsi   = 100 - (100 / (1 + rs))
    return rsi.iloc[-1]


def sma_signal(price_raw, sma_raw, label):
    """Return a plain-English sentence fragment for price vs SMA."""
    try:
        pct = (price_raw - sma_raw) / sma_raw * 100
        direction = "above" if price_raw >= sma_raw else "below"
        return (
            f"{pct:+.1f}% {direction} its {label} of "
            f"{safe(sma_raw, 'price')}"
        )
    except Exception:
        return f"compared to its {label} of {safe(sma_raw, 'price')}"


def rsi_signal(rsi_raw):
    """Return a plain-English RSI interpretation."""
    try:
        if rsi_raw >= 70:
            return f"an RSI (14-day) of {rsi_raw:.2f}, which is in overbought territory (above 70)"
        elif rsi_raw <= 30:
            return f"an RSI (14-day) of {rsi_raw:.2f}, which is in oversold territory (below 30)"
        else:
            return f"an RSI (14-day) of {rsi_raw:.2f}, which is in neutral territory"
    except Exception:
        return f"an RSI (14-day) of {safe(rsi_raw, '2f')}"


def de_signal(de_raw):
    """Return a plain-English debt-to-equity context note."""
    try:
        if de_raw > 200:
            return " — very high leverage"
        elif de_raw > 100:
            return " — elevated but common for large-caps with buyback programmes"
        elif de_raw > 50:
            return " — moderate leverage"
        else:
            return " — conservative leverage"
    except Exception:
        return ""


def cr_signal(cr_raw):
    """Return a plain-English current ratio context note."""
    try:
        if cr_raw >= 2:
            return " (strong short-term liquidity)"
        elif cr_raw >= 1:
            return " (adequate short-term liquidity)"
        else:
            return " (current liabilities exceed current assets — watch liquidity)"
    except Exception:
        return ""


def beta_signal(beta_raw):
    """Return a plain-English beta context note."""
    try:
        if beta_raw > 1.5:
            return f" — high volatility, moves roughly {beta_raw:.1f}x the market on average"
        elif beta_raw > 1.0:
            return " — moderately more volatile than the broader market"
        elif beta_raw > 0:
            return " — less volatile than the broader market"
        else:
            return " — moves inversely to the broader market"
    except Exception:
        return ""


