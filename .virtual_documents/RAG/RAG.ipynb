def _kb_file_path(ticker: str) -> str:
    return os.path.join(OUTPUT_DIR_HTML, f"{ticker.lower()}.html")
 
 
def _kb_is_fresh(ticker: str, max_age_hours: float = KB_STALENESS_HOURS) -> bool:
    path = _kb_file_path(ticker)
    if not os.path.exists(path):
        return False
    age_hours = (datetime.datetime.now().timestamp() - os.path.getmtime(path)) / 3600
    return age_hours < max_age_hours
 
 
def _ensure_kb_files(tickers: list[str], force: bool = False) -> list[str]:
    to_generate: dict[str, dict] = {}
    for ticker in tickers:
        if force or not _kb_is_fresh(ticker):
            meta = _build_ticker_meta(ticker)
            if meta is None:
                print(f"  ⚠  Could not resolve meta for {ticker} — skipping")
                continue
            to_generate[ticker] = meta
        else:
            print(f"  ✓ {ticker}: KB file is fresh, skipping regeneration")
    if to_generate:
        generate_tickers(to_generate)
        convert_tickers_into_txt_csv()
    return list(to_generate.keys())
 
 
def _load_documents_from_csv(csv_path: str = OUTPUT_CSV) -> list[dict]:
    df = pd.read_csv(csv_path)
    documents = []
    for _, row in df.iterrows():
        ticker = row["ticker"]
        for section in str(row["text"]).split("\n\n"):
            section_clean = section.strip()
            if section_clean:
                documents.append({"ticker": ticker, "text": section_clean})
    return documents
 
 
def _build_or_load_chroma(
    documents: list[dict],
    model: SentenceTransformer,
    client: chromadb.PersistentClient,
) -> chromadb.Collection:
    collection = client.get_or_create_collection(name=COLLECTION_NAME)
    texts      = [d["text"] for d in documents]
    metadatas  = [{"ticker": d["ticker"]} for d in documents]
    ids        = [str(i) for i in range(len(documents))]
    embeddings = model.encode(texts, convert_to_numpy=True, show_progress_bar=False)
    collection.upsert(
        documents=texts,
        embeddings=embeddings.tolist(),
        metadatas=metadatas,
        ids=ids,
    )
    return collection
 
 
def _hybrid_retrieve(
    query:       str,
    documents:   list[dict],
    collection:  chromadb.Collection,
    model:       SentenceTransformer,
    top_k:       int   = 5,
    bm25_weight: float = 0.3,
    vec_weight:  float = 0.7,
) -> list[dict]:
    """Hybrid BM25 + vector retrieval with min-max normalised fusion scores."""
    texts = [d["text"] for d in documents]
    n     = len(texts)
 
    # BM25
    bm25        = BM25Okapi([t.split() for t in texts])
    bm25_raw    = bm25.get_scores(query.split())
    bm25_min, bm25_max = bm25_raw.min(), bm25_raw.max()
    bm25_norm   = (
        (bm25_raw - bm25_min) / (bm25_max - bm25_min)
        if bm25_max > bm25_min else np.zeros(n)
    )
 
    # Vector
    q_emb       = model.encode([query], convert_to_numpy=True)
    vec_results = collection.query(
        query_embeddings=q_emb.tolist(),
        n_results=min(top_k * 4, n),
        include=["distances", "metadatas"],
    )
    vec_scores_raw = np.zeros(n)
    for idx, dist in zip(
        [int(i) for i in vec_results["ids"][0]],
        vec_results["distances"][0],
    ):
        vec_scores_raw[idx] = 1.0 / (1.0 + dist)
 
    vec_min, vec_max = vec_scores_raw.min(), vec_scores_raw.max()
    vec_norm = (
        (vec_scores_raw - vec_min) / (vec_max - vec_min)
        if vec_max > vec_min else np.zeros(n)
    )
 
    fused       = bm25_weight * bm25_norm + vec_weight * vec_norm
    top_indices = fused.argsort()[-top_k:][::-1]
 
    return [
        {
            "rank":     int(rank + 1),
            "ticker":   documents[i]["ticker"],
            "text":     documents[i]["text"],
            "score":    float(fused[i]),
            "bm25_raw": float(bm25_raw[i]),
            "vec_sim":  float(vec_scores_raw[i]),
            "source":   "yfinance",
        }
        for rank, i in enumerate(top_indices)
    ]
 
 
# =============================================================================
# SECTION 2 — POST-PROCESSING
# =============================================================================
 
def _post_process(
    results:          list[dict],
    resolved_tickers: list[str],
    score_threshold:  float = RELEVANCE_THRESHOLD,
) -> list[dict]:
    """
    Option 1 — Relevance Filtering
    --------------------------------
    Drop any chunk whose fused score is below `score_threshold`.
    Rationale: low-score chunks add noise to the LLM context, waste tokens,
    and can cause the model to hedge or contradict higher-quality chunks.
    The threshold (default 0.15) is applied to the normalised fusion score.
 
    Option 2 — Citation Enforcement
    --------------------------------
    Attach structured source metadata to every surviving chunk:
      citation_id  — stable ID (TICKER-rank) the LLM must reference per claim
      source_url   — canonical Yahoo Finance page for human/automated verification
      source_type  — data provenance tag ("yfinance")
      relevant_to  — which queried tickers this chunk was retrieved for
 
    This metadata is embedded directly in the generation prompt so the LLM
    can cite sources inline, and the groundedness checker can verify them.
    """
    processed = []
    for chunk in results:
 
        # ── Option 1: relevance filtering ────────────────────────────────────
        if chunk["score"] < score_threshold:
            print(
                f"  ✂  Filtered [{chunk['ticker']}] rank={chunk['rank']} "
                f"score={chunk['score']:.3f} < threshold {score_threshold}"
            )
            continue
 
        # ── Option 2: citation enforcement ───────────────────────────────────
        ticker = chunk["ticker"]
        chunk["citation_id"] = f"{ticker}-{chunk['rank']}"
        chunk["source_url"]  = f"https://finance.yahoo.com/quote/{ticker}/"
        chunk["source_type"] = "yfinance"
        chunk["relevant_to"] = resolved_tickers
        processed.append(chunk)
 
    return processed
 
 
# =============================================================================
# SECTION 3 — RETRIEVAL EVALUATION
# =============================================================================
 
def _compute_recall_at_k(
    results:          list[dict],
    relevant_tickers: list[str],
    k:                int,
) -> float:
    """
    Recall@K = |{relevant tickers found in top-K}| / |{relevant tickers}|
 
    A chunk is "relevant" if its ticker is in the set of tickers resolved from
    the query. This is the natural ground truth for financial Q&A: if the user
    asks about LULU, any LULU chunk is a true positive.
 
    Returns 1.0 if relevant_tickers is empty (nothing to miss).
    """
    if not relevant_tickers:
        return 1.0
    top_k_tickers = {r["ticker"] for r in results[:k]}
    found = len(set(relevant_tickers) & top_k_tickers)
    return round(found / len(relevant_tickers), 4)
 
 
def _compute_mrr(
    results:          list[dict],
    relevant_tickers: list[str],
) -> float:
    """
    MRR = mean(1 / rank_of_first_relevant_chunk) across all resolved tickers.
 
    If a ticker is never retrieved, its reciprocal rank is 0.
    Range: [0, 1].  Higher is better.
 
    MRR is chosen alongside Recall@K because it captures position quality:
    a system that always retrieves the right chunk at rank 1 (MRR=1.0) is
    much more useful than one that buries it at rank 10 (MRR=0.1), even if
    Recall@K is identical for both.
    """
    if not relevant_tickers:
        return 1.0
    reciprocal_ranks = []
    for ticker in relevant_tickers:
        rr = 0.0
        for chunk in results:
            if chunk["ticker"] == ticker:
                rr = 1.0 / chunk["rank"]
                break
        reciprocal_ranks.append(rr)
    return round(sum(reciprocal_ranks) / len(reciprocal_ranks), 4)
 
 
def _compute_retrieval_metrics(
    results:          list[dict],
    relevant_tickers: list[str],
    k:                int,
) -> dict:
    """Compute Recall@K and MRR, with justification text and diagnostic flags."""
    recall = _compute_recall_at_k(results, relevant_tickers, k)
    mrr    = _compute_mrr(results, relevant_tickers)
 
    justification = {
        "Recall@K": (
            f"Recall@{k}={recall:.4f}. Measures what fraction of the queried "
            f"tickers ({relevant_tickers}) appear in the top-{k} retrieved chunks. "
            "A score < 1.0 means at least one ticker was missed entirely — "
            "the LLM cannot generate accurate facts about a company if no chunks "
            "for that company were retrieved."
        ),
        "MRR": (
            f"MRR={mrr:.4f}. Measures how high in the ranking the first relevant "
            "chunk appears. A low MRR means relevant context is buried behind "
            "less-relevant chunks the LLM reads first. Target MRR > 0.5 for "
            "reliable generation quality."
        ),
    }
 
    flags = []
    if recall < 1.0:
        missing = set(relevant_tickers) - {r["ticker"] for r in results[:k]}
        flags.append(
            f"RECALL_MISS: tickers not in top-{k}: {sorted(missing)}"
        )
    if mrr < 0.5:
        avg_rank = round(1 / mrr, 1) if mrr > 0 else float("inf")
        flags.append(
            f"LOW_MRR: first relevant chunk appears on average at rank {avg_rank} "
            "— consider increasing top_k or retuning BM25/vector weights"
        )
 
    return {
        f"Recall@{k}":     recall,
        "MRR":              mrr,
        "justification":    justification,
        "diagnostic_flags": flags,
    }
 
 
