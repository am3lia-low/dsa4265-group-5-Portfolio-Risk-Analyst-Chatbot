_SYSTEM_PROMPT = """\
You are a structured financial risk analyst for a portfolio management chatbot.
Answer the user's question using ONLY the provided context chunks.
Do not use any external knowledge.
 
RULES:
1. Output valid JSON only — no markdown fences, no preamble.
2. Every factual claim must include a "citation_id" from the context.
3. All numerical values must be numbers (not strings): e.g. 0.23 not "23%".
4. If a fact is not found in context, set the value to null.
5. Be concise but specific.
 
OUTPUT SCHEMA:
{
  "answer_summary": "<1-3 sentence plain-English summary>",
  "key_facts": [
    {
      "claim":       "<factual statement>",
      "value":       <number or null>,
      "unit":        "<%, $, ratio, etc. or null>",
      "citation_id": "<citation_id from context>",
      "source_url":  "<source_url from context>"
    }
  ],
  "sentiment":      "<bullish | bearish | neutral | mixed>",
  "risk_level":     "<low | moderate | high | very_high | null>",
  "confidence":     <0.0-1.0>,
  "tickers_cited":  ["TICK1"],
  "kb_sources_used": ["tickers", "portfolio", "macro", "concepts", "strategies"],
  "data_gaps":      ["<field not found in context>"],
  "recommended_actions": ["<actionable recommendation>"]
}
"""
 
 
def _build_generation_prompt(query: str, chunks: list[dict]) -> str:
    context_lines = []
    for chunk in chunks:
        source_label = COLLECTION_LABELS.get(chunk.get("kb_source", ""), chunk.get("kb_source", ""))
        context_lines.append(
            f"[{chunk['citation_id']}] "
            f"(source: {chunk.get('source_url', 'internal')}, "
            f"kb: {source_label}, "
            f"ticker: {chunk.get('ticker', 'N/A')})\n"
            f"{chunk['text']}"
        )
    return (
        f"CONTEXT:\n" + "\n\n---\n\n".join(context_lines)
        + f"\n\nQUESTION: {query}\n\n"
        "Answer in JSON only."
    )
 
 
def _generate_finance_llama(
    system_prompt: str,
    user_prompt:   str,
    model_path:    str,
    max_tokens:    int   = 1024,
    temperature:   float = 0.1,
) -> str:
    try:
        from llama_cpp import Llama
    except ImportError:
        raise ImportError("Run: pip install llama-cpp-python")
    llm  = Llama(model_path=model_path, n_ctx=4096, n_threads=os.cpu_count(), verbose=False)
    resp = llm.create_chat_completion(
        messages=[
            {"role": "system", "content": system_prompt},
            {"role": "user",   "content": user_prompt},
        ],
        max_tokens=max_tokens, temperature=temperature,
    )
    return resp["choices"][0]["message"]["content"].strip()
 
 
_FINGPT_MODELS = {
    "mt":         "FinGPT/fingpt-mt_llama2-7b_lora",
    "sentiment":  "FinGPT/fingpt-sentiment_llama2-13b_lora",
    "forecaster": "FinGPT/fingpt-forecaster_dow30_llama2-7b_lora",
}
 
 
def _generate_fingpt(
    system_prompt:  str,
    user_prompt:    str,
    variant:        str   = "mt",
    max_new_tokens: int   = 512,
    temperature:    float = 0.1,
) -> str:
    try:
        import torch
        from transformers import AutoTokenizer, AutoModelForCausalLM, BitsAndBytesConfig
        from peft import PeftModel
    except ImportError:
        raise ImportError("Run: pip install transformers peft accelerate bitsandbytes")
 
    adapter  = _FINGPT_MODELS.get(variant)
    base_id  = "meta-llama/Llama-2-13b-hf" if "13b" in adapter else "meta-llama/Llama-2-7b-hf"
    bnb_cfg  = BitsAndBytesConfig(load_in_4bit=True, bnb_4bit_compute_dtype=__import__("torch").float16)
    tok      = AutoTokenizer.from_pretrained(base_id)
    base     = AutoModelForCausalLM.from_pretrained(base_id, quantization_config=bnb_cfg, device_map="auto")
    model    = PeftModel.from_pretrained(base, adapter)
    model.eval()
    prompt   = f"[INST] <<SYS>>\n{system_prompt}\n<</SYS>>\n\n{user_prompt} [/INST]"
    inputs   = tok(prompt, return_tensors="pt").to(model.device)
    with __import__("torch").no_grad():
        out = model.generate(**inputs, max_new_tokens=max_new_tokens,
                             temperature=temperature, do_sample=temperature > 0,
                             pad_token_id=tok.eos_token_id)
    return tok.decode(out[0][inputs["input_ids"].shape[1]:], skip_special_tokens=True).strip()
 
 
def generate_answer(
    query:          str,
    chunks:         list[dict],
    backend:        str        = GEN_BACKEND_FINANCE_LLAMA,
    model_path:     str | None = None,
    fingpt_variant: str        = "mt",
    max_tokens:     int        = 1024,
    temperature:    float      = 0.1,
) -> dict:
    user_prompt = _build_generation_prompt(query, chunks)
    raw         = ""
    try:
        if backend == GEN_BACKEND_FINANCE_LLAMA:
            if not model_path:
                raise ValueError("model_path required for finance_llama")
            raw = _generate_finance_llama(_SYSTEM_PROMPT, user_prompt, model_path, max_tokens, temperature)
        elif backend == GEN_BACKEND_FINGPT:
            raw = _generate_fingpt(_SYSTEM_PROMPT, user_prompt, fingpt_variant, max_tokens, temperature)
        else:
            raise ValueError(f"Unknown backend '{backend}'")
    except Exception as e:
        return {"raw_output": "", "parsed_output": None, "generation_error": str(e)}
 
    clean  = re.sub(r"^```(?:json)?\s*", "", raw.strip())
    clean  = re.sub(r"\s*```$", "", clean)
    parsed = None
    err    = None
    try:
        parsed = json.loads(clean)
    except json.JSONDecodeError as e:
        err = f"JSON parse error: {e}"
    return {"raw_output": raw, "parsed_output": parsed, "generation_error": err}
 
 
