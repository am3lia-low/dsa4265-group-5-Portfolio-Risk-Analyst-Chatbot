# SECTION 4 — GENERATION
# =============================================================================
 
_SYSTEM_PROMPT = """\
You are a structured financial analyst. Answer the user's question using ONLY
the provided context chunks. Do not use any external knowledge.
 
RULES:
1. Output valid JSON only — no markdown fences, no preamble.
2. Every factual claim must include a "citation_id" taken from the context header.
3. All numerical values must be numbers (not strings): e.g. 0.23 not "23%".
4. If a fact is not found in the context, set the value to null.
5. Be concise but complete.
 
OUTPUT SCHEMA (return exactly this structure):
{
  "answer_summary": "<1-3 sentence plain-English summary>",
  "key_facts": [
    {
      "claim":       "<factual statement>",
      "value":       <number or null>,
      "unit":        "<%, $, ratio, etc. — or null>",
      "citation_id": "<citation_id from context>",
      "source_url":  "<source_url from context>"
    }
  ],
  "sentiment":     "<bullish | bearish | neutral>",
  "confidence":    <0.0-1.0>,
  "tickers_cited": ["TICK1"],
  "data_gaps":     ["<field not found in context>"]
}
"""
 
 
def _build_generation_prompt(query: str, chunks: list[dict]) -> str:
    """Embed annotated context chunks into the user-turn prompt."""
    context_lines = []
    for chunk in chunks:
        context_lines.append(
            f"[{chunk['citation_id']}] "
            f"(source: {chunk['source_url']}, ticker: {chunk['ticker']})\n"
            f"{chunk['text']}"
        )
    context_block = "\n\n---\n\n".join(context_lines)
    return (
        f"CONTEXT:\n{context_block}\n\n"
        f"QUESTION: {query}\n\n"
        "Answer in JSON only, following the schema exactly."
    )
 
 
# ── Finance-Llama backend (GGUF via llama-cpp-python) ────────────────────────
 
def _generate_finance_llama(
    system_prompt: str,
    user_prompt:   str,
    model_path:    str,
    max_tokens:    int   = 1024,
    temperature:   float = 0.1,
) -> str:
    """
    Finance-Llama-3.1-8B (or any GGUF) via llama-cpp-python.
 
    Setup:
        pip install llama-cpp-python
        huggingface-cli download bartowski/Finance-Llama-3.1-8B-GGUF \
            Finance-Llama-3.1-8B-Q4_K_M.gguf --local-dir /models/
 
    Parameters
    ----------
    model_path : local path to the downloaded .gguf file
    """
    try:
        from llama_cpp import Llama
    except ImportError:
        raise ImportError("Run: pip install llama-cpp-python")
 
    llm = Llama(
        model_path=model_path,
        n_ctx=4096,
        n_threads=os.cpu_count(),
        verbose=False,
    )
    resp = llm.create_chat_completion(
        messages=[
            {"role": "system", "content": system_prompt},
            {"role": "user",   "content": user_prompt},
        ],
        max_tokens=max_tokens,
        temperature=temperature,
    )
    return resp["choices"][0]["message"]["content"].strip()
 
 
# ── FinGPT backend (HuggingFace transformers + peft) ─────────────────────────
 
_FINGPT_MODELS = {
    "mt":         "FinGPT/fingpt-mt_llama2-7b_lora",
    "sentiment":  "FinGPT/fingpt-sentiment_llama2-13b_lora",
    "forecaster": "FinGPT/fingpt-forecaster_dow30_llama2-7b_lora",
}
 
 
def _generate_fingpt(
    system_prompt:  str,
    user_prompt:    str,
    variant:        str   = "mt",
    max_new_tokens: int   = 512,
    temperature:    float = 0.1,
) -> str:
    """
    FinGPT LoRA variant on top of Llama-2.
 
    Setup:
        pip install transformers peft accelerate bitsandbytes
        # Requires HuggingFace access to meta-llama/Llama-2-*-hf
 
    Parameters
    ----------
    variant : "mt" | "sentiment" | "forecaster"
    """
    try:
        import torch
        from transformers import AutoTokenizer, AutoModelForCausalLM, BitsAndBytesConfig
        from peft import PeftModel
    except ImportError:
        raise ImportError("Run: pip install transformers peft accelerate bitsandbytes")
 
    adapter_repo  = _FINGPT_MODELS.get(variant)
    if adapter_repo is None:
        raise ValueError(f"Unknown FinGPT variant '{variant}'. Choose: {list(_FINGPT_MODELS)}")
 
    base_id = (
        "meta-llama/Llama-2-13b-hf"
        if "13b" in adapter_repo
        else "meta-llama/Llama-2-7b-hf"
    )
    bnb_cfg   = BitsAndBytesConfig(load_in_4bit=True, bnb_4bit_compute_dtype=torch.float16)
    tokenizer = AutoTokenizer.from_pretrained(base_id)
    base      = AutoModelForCausalLM.from_pretrained(
        base_id, quantization_config=bnb_cfg, device_map="auto"
    )
    model = PeftModel.from_pretrained(base, adapter_repo)
    model.eval()
 
    full_prompt = f"[INST] <<SYS>>\n{system_prompt}\n<</SYS>>\n\n{user_prompt} [/INST]"
    inputs      = tokenizer(full_prompt, return_tensors="pt").to(model.device)
    with __import__("torch").no_grad():
        out_ids = model.generate(
            **inputs,
            max_new_tokens=max_new_tokens,
            temperature=temperature,
            do_sample=temperature > 0,
            pad_token_id=tokenizer.eos_token_id,
        )
    generated = out_ids[0][inputs["input_ids"].shape[1]:]
    return tokenizer.decode(generated, skip_special_tokens=True).strip()
 
 
# ── Generation dispatcher ─────────────────────────────────────────────────────
 
def generate_answer(
    query:          str,
    chunks:         list[dict],
    backend:        str        = GEN_BACKEND_FINANCE_LLAMA,
    model_path:     str | None = None,
    fingpt_variant: str        = "mt",
    max_tokens:     int        = 1024,
    temperature:    float      = 0.1,
) -> dict:
    """
    Generate a structured JSON answer from post-processed retrieved chunks.
 
    Returns
    -------
    {
      "raw_output":       str,       # LLM text output before parsing
      "parsed_output":    dict|None, # parsed JSON or None on failure
      "generation_error": str|None,  # error message if something failed
    }
    """
    user_prompt = _build_generation_prompt(query, chunks)
    raw_output  = ""
 
    try:
        if backend == GEN_BACKEND_FINANCE_LLAMA:
            if not model_path:
                raise ValueError("model_path is required for finance_llama backend")
            raw_output = _generate_finance_llama(
                _SYSTEM_PROMPT, user_prompt, model_path, max_tokens, temperature
            )
        elif backend == GEN_BACKEND_FINGPT:
            raw_output = _generate_fingpt(
                _SYSTEM_PROMPT, user_prompt, fingpt_variant, max_tokens, temperature
            )
        else:
            raise ValueError(f"Unknown backend '{backend}'")
    except Exception as e:
        return {"raw_output": "", "parsed_output": None, "generation_error": str(e)}
 
    # Strip accidental markdown fences
    clean = re.sub(r"^```(?:json)?\s*", "", raw_output.strip())
    clean = re.sub(r"\s*```$", "", clean)
 
    parsed      = None
    parse_error = None
    try:
        parsed = json.loads(clean)
    except json.JSONDecodeError as e:
        parse_error = f"JSON parse error: {e}"
 
    return {
        "raw_output":       raw_output,
        "parsed_output":    parsed,
        "generation_error": parse_error,
    }
 
 
# =============================================================================
# SECTION 5 — GENERATION EVALUATION
# =============================================================================
 
def _bertscore(hypothesis: str, references: list[str]) -> dict[str, float]:
    """
    BERTScore Precision, Recall, F1 between the generated summary and
    the retrieved chunks (used as references).
 
    Falls back to token-overlap approximation if bert-score is not installed.
    Install: pip install bert-score
    """
    try:
        from bert_score import score as bs_score
        import torch
        P, R, F1 = bs_score(
            [hypothesis] * len(references),
            references,
            lang="en",
            verbose=False,
            device="cuda" if torch.cuda.is_available() else "cpu",
        )
        return {
            "precision": round(float(P.mean()), 4),
            "recall":    round(float(R.mean()), 4),
            "f1":        round(float(F1.mean()), 4),
            "method":    "bertscore",
        }
    except ImportError:
        warnings.warn(
            "bert-score not installed — using token-overlap fallback. "
            "Run `pip install bert-score` for proper scores.",
            stacklevel=2,
        )
        hyp_tokens = set(hypothesis.lower().split())
        scores = []
        for ref in references:
            ref_tokens = set(ref.lower().split())
            if not ref_tokens:
                continue
            p = len(hyp_tokens & ref_tokens) / len(hyp_tokens) if hyp_tokens else 0.0
            r = len(hyp_tokens & ref_tokens) / len(ref_tokens)
            f = (2 * p * r / (p + r)) if (p + r) > 0 else 0.0
            scores.append((p, r, f))
        if not scores:
            return {"precision": 0.0, "recall": 0.0, "f1": 0.0, "method": "token_overlap_fallback"}
        return {
            "precision": round(sum(s[0] for s in scores) / len(scores), 4),
            "recall":    round(sum(s[1] for s in scores) / len(scores), 4),
            "f1":        round(sum(s[2] for s in scores) / len(scores), 4),
            "method":    "token_overlap_fallback",
        }
 
 
def _groundedness_check(
    parsed_output: dict | None,
    chunks:        list[dict],
) -> dict:
    """
    Citation Validity Check.
 
    For each claim in key_facts:
      1. Look up the cited chunk by citation_id.
      2. Search the chunk text for the claimed numerical value (±1% tolerance).
      3. Assign verdict: GROUNDED | UNVERIFIED | HALLUCINATED
 
    HALLUCINATED  — citation_id not found in retrieved chunks at all
    UNVERIFIED    — citation_id exists but the number wasn't found in its text
                    (may be derived/transformed, not necessarily wrong)
    GROUNDED      — citation_id exists and number is present in the source text
    """
    if not parsed_output:
        return {"status": "skipped", "reason": "no parsed output to evaluate"}
 
    chunk_map = {c["citation_id"]: c["text"] for c in chunks}
    verdicts  = []
 
    for fact in parsed_output.get("key_facts", []):
        cid   = fact.get("citation_id", "")
        value = fact.get("value")
        claim = fact.get("claim", "")
 
        if cid not in chunk_map:
            verdicts.append({
                "claim": claim, "citation_id": cid, "value": value,
                "verdict": "HALLUCINATED",
                "reason":  "citation_id not found in retrieved chunks",
            })
            continue
 
        if value is None:
            verdicts.append({
                "claim": claim, "citation_id": cid, "value": value,
                "verdict": "GROUNDED",
                "reason":  "null value — no number to verify",
            })
            continue
 
        numbers = [
            float(n.replace(",", ""))
            for n in re.findall(r"-?\d[\d,]*\.?\d*", chunk_map[cid])
        ]
        tol     = abs(value) * 0.01 if value != 0 else 0.01
        matched = any(abs(n - value) <= tol for n in numbers)
 
        verdicts.append({
            "claim": claim, "citation_id": cid, "value": value,
            "verdict": "GROUNDED" if matched else "UNVERIFIED",
            "reason": (
                "numerical value found in source chunk"
                if matched else
                "value not directly found — may be derived or transformed"
            ),
        })
 
    n        = len(verdicts)
    grounded = sum(1 for v in verdicts if v["verdict"] == "GROUNDED")
    unverif  = sum(1 for v in verdicts if v["verdict"] == "UNVERIFIED")
    halluc   = sum(1 for v in verdicts if v["verdict"] == "HALLUCINATED")
 
    return {
        "total_claims":      n,
        "grounded":          grounded,
        "unverified":        unverif,
        "hallucinated":      halluc,
        "groundedness_rate": round(grounded / n, 4) if n else 1.0,
        "claim_verdicts":    verdicts,
    }
 
 
def _evaluate_generation(
    parsed_output: dict | None,
    chunks:        list[dict],
) -> dict:
    if not parsed_output:
        return {"bertscore": None, "groundedness": None}
    return {
        "bertscore":    _bertscore(
            parsed_output.get("answer_summary", ""),
            [c["text"] for c in chunks],
        ),
        "groundedness": _groundedness_check(parsed_output, chunks),
    }
 
 
# =============================================================================
# SECTION 6 — PERSISTENCE
# =============================================================================
 
def _query_hash(query: str) -> str:
    return hashlib.md5(query.encode()).hexdigest()[:10]
 
 
def _save_retrieval_log(
    query:            str,
    resolved_tickers: list[str],
    raw_results:      list[dict],
    filtered_results: list[dict],
    metrics:          dict,
) -> str:
    """
    Persist retrieval results and evaluation metrics as JSON.
 
    Top-level schema
    ----------------
    query                : original query string
    timestamp            : ISO-8601
    resolved_tickers     : tickers parsed from the query
    top_k                : number of raw results before filtering
    score_threshold      : RELEVANCE_THRESHOLD used
    retrieval_metrics    : { Recall@K, MRR, justification, diagnostic_flags }
    chunks_before_filter : int
    chunks_after_filter  : int
    retrieved_chunks     : list of chunk dicts (post-processed, with citation fields)
 
    Rationale for JSON (vs CSV):
      • Nested structures (metrics.justification, chunk.relevant_to) map naturally
      • Each file is a self-contained audit record for a single query
      • Easy to reload for offline analysis or metric aggregation
    """
    os.makedirs(RETRIEVAL_LOG_DIR, exist_ok=True)
    ts   = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    path = os.path.join(RETRIEVAL_LOG_DIR, f"retrieval_{ts}_{_query_hash(query)}.json")
 
    with open(path, "w", encoding="utf-8") as f:
        json.dump({
            "query":                query,
            "timestamp":            datetime.datetime.now().isoformat(),
            "resolved_tickers":     resolved_tickers,
            "top_k":                len(raw_results),
            "score_threshold":      RELEVANCE_THRESHOLD,
            "retrieval_metrics":    metrics,
            "chunks_before_filter": len(raw_results),
            "chunks_after_filter":  len(filtered_results),
            "retrieved_chunks":     filtered_results,
        }, f, indent=2, default=str)
 
    print(f"  💾 Retrieval log → {path}")
    return path
 
 
def _save_generation_log(
    query:              str,
    gen_result:         dict,
    gen_eval:           dict,
    chunks:             list[dict],
    retrieval_log_path: str,
) -> str:
    """
    Persist generation output and evaluation metrics as JSON.
 
    Top-level schema
    ----------------
    query                : original query string
    timestamp            : ISO-8601
    retrieval_log_path   : cross-reference to the retrieval log
    generation           : { raw_output, parsed_output, generation_error }
    evaluation           : { bertscore: {precision, recall, f1},
                              groundedness: {total_claims, grounded, unverified,
                                             hallucinated, groundedness_rate,
                                             claim_verdicts} }
    chunks_used          : lightweight chunk summary (citation_id, ticker, score)
    """
    os.makedirs(GENERATION_LOG_DIR, exist_ok=True)
    ts   = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    path = os.path.join(GENERATION_LOG_DIR, f"generation_{ts}_{_query_hash(query)}.json")
 
    with open(path, "w", encoding="utf-8") as f:
        json.dump({
            "query":               query,
            "timestamp":           datetime.datetime.now().isoformat(),
            "retrieval_log_path":  retrieval_log_path,
            "generation":          gen_result,
            "evaluation":          gen_eval,
            "chunks_used": [
                {
                    "citation_id": c.get("citation_id", ""),
                    "ticker":      c["ticker"],
                    "source_url":  c.get("source_url", ""),
                    "score":       c["score"],
                }
                for c in chunks
            ],
        }, f, indent=2, default=str)
 
    print(f"  💾 Generation log → {path}")
    return path
    



# =============================================================================
# SECTION 7 — Retrieve_context() function
# =============================================================================
 
def retrieve_context(
    query:              str,
    top_k:              int   = 5,
    force_refresh:      bool  = False,
    kb_staleness_hours: float = KB_STALENESS_HOURS,
    fallback_to_all:    bool  = True,
    score_threshold:    float = RELEVANCE_THRESHOLD,
    save_log:           bool  = True,
) -> tuple[list[dict], dict, str]:
    """
    Retrieval stage only: resolve → KB gen → embed → hybrid search →
    post-process → eval → save log.
 
    Returns
    -------
    (filtered_chunks, retrieval_metrics, log_path)
    """
    resolved_tickers = resolve_tickers_from_query(query)
 
    if resolved_tickers:
        print(f"\n🔍 Resolved tickers: {resolved_tickers}")
        _ensure_kb_files(resolved_tickers, force=force_refresh)
    else:
        print("\n⚠  No tickers resolved.")
        if fallback_to_all:
            print("   Falling back to full KB.")
            if not os.path.exists(OUTPUT_CSV):
                convert_tickers_into_txt_csv()
        else:
            return [], {}, ""
 
    if not os.path.exists(OUTPUT_CSV):
        print("  ⚠  No CSV found.")
        return [], {}, ""
 
    documents = _load_documents_from_csv(OUTPUT_CSV)
    if not documents:
        print("  ⚠  No documents loaded.")
        return [], {}, ""
 
    print(f"   Loaded {len(documents)} chunks")
 
    model      = SentenceTransformer(EMBED_MODEL_NAME)
    client     = chromadb.PersistentClient(path=VECTOR_DB_DIR)
    collection = _build_or_load_chroma(documents, model, client)
 
    raw_results      = _hybrid_retrieve(query, documents, collection, model, top_k=top_k)
    filtered_results = _post_process(raw_results, resolved_tickers, score_threshold)
    metrics          = _compute_retrieval_metrics(raw_results, resolved_tickers, k=top_k)
 
    print(
        f"\n📊 Retrieval  Recall@{top_k}: {metrics[f'Recall@{top_k}']:.4f}  "
        f"MRR: {metrics['MRR']:.4f}"
    )
    for flag in metrics.get("diagnostic_flags", []):
        print(f"  ⚠  {flag}")
 
    print(f"\n📄 {len(filtered_results)} chunks after filtering (was {len(raw_results)}):")
    for r in filtered_results:
        print(f"  [{r['rank']}] [{r['ticker']}] score={r['score']:.3f}  {r['text'][:70]}…")
 
    log_path = ""
    if save_log:
        log_path = _save_retrieval_log(
            query, resolved_tickers, raw_results, filtered_results, metrics
        )
 
    return filtered_results, metrics, log_path
 
 
def run_pipeline(
    query:           str,
    top_k:           int        = 5,
    force_refresh:   bool       = False,
    score_threshold: float      = RELEVANCE_THRESHOLD,
    backend:         str        = GEN_BACKEND_FINANCE_LLAMA,
    model_path:      str | None = None,
    fingpt_variant:  str        = "mt",
    max_tokens:      int        = 1024,
    temperature:     float      = 0.1,
    save_logs:       bool       = True,
) -> dict:
    """
    Full end-to-end pipeline: Retrieval → Generation → Evaluation → Persist.
 
    Parameters
    ----------
    query           : Natural language financial question
    top_k           : Number of chunks to retrieve before filtering
    force_refresh   : Force KB regeneration regardless of file age
    score_threshold : Minimum fused score for a chunk to pass filtering
    backend         : "finance_llama" | "fingpt"
    model_path      : Local .gguf file path  (finance_llama backend only)
                      e.g. "/models/Finance-Llama-3.1-8B-Q4_K_M.gguf"
    fingpt_variant  : "mt" | "sentiment" | "forecaster"  (fingpt backend only)
    max_tokens      : Max tokens for generation
    temperature     : Sampling temperature  (0.0 = deterministic)
    save_logs       : Write retrieval + generation JSON logs to disk
 
    Returns
    -------
    {
      query, resolved_tickers, chunks,
      retrieval_metrics,              # Recall@K, MRR, flags
      generation,                     # raw_output, parsed_output, error
      gen_eval,                       # bertscore, groundedness
      retrieval_log_path,
      generation_log_path,
    }
    """
    # Retrieval
    chunks, ret_metrics, ret_log = retrieve_context(
        query=query,
        top_k=top_k,
        force_refresh=force_refresh,
        score_threshold=score_threshold,
        save_log=save_logs,
    )
 
    if not chunks:
        print("  ⚠  No chunks after filtering — skipping generation.")
        return {
            "query": query, "resolved_tickers": [],
            "chunks": [], "retrieval_metrics": ret_metrics,
            "generation": None, "gen_eval": None,
            "retrieval_log_path": ret_log, "generation_log_path": "",
        }
 
    # Generation
    print(f"\n🤖 Generating with backend='{backend}'…")
    gen_result = generate_answer(
        query=query, chunks=chunks, backend=backend,
        model_path=model_path, fingpt_variant=fingpt_variant,
        max_tokens=max_tokens, temperature=temperature,
    )
    if gen_result["generation_error"]:
        print(f"  ⚠  Generation error: {gen_result['generation_error']}")
 
    # Evaluation
    print("\n📏 Evaluating generation…")
    gen_eval = _evaluate_generation(gen_result["parsed_output"], chunks)
 
    if gen_eval.get("bertscore"):
        bs = gen_eval["bertscore"]
        print(f"  BERTScore  Precision: {bs['precision']:.4f}  F1: {bs['f1']:.4f}")
    if gen_eval.get("groundedness"):
        gd = gen_eval["groundedness"]
        print(
            f"  Groundedness  {gd['grounded']}/{gd['total_claims']} grounded "
            f"({gd['groundedness_rate']:.1%})  "
            f"{gd['hallucinated']} hallucinated"
        )
 
    # Persist
    gen_log = ""
    if save_logs:
        gen_log = _save_generation_log(query, gen_result, gen_eval, chunks, ret_log)
 
    return {
        "query":                query,
        "resolved_tickers":     resolve_tickers_from_query(query),
        "chunks":               chunks,
        "retrieval_metrics":    ret_metrics,
        "generation":           gen_result,
        "gen_eval":             gen_eval,
        "retrieval_log_path":   ret_log,
        "generation_log_path":  gen_log,
    }


