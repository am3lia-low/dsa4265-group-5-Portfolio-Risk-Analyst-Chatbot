# SECTION 8 — GENERATION EVALUATION
# =============================================================================
 
def _bertscore(hypothesis: str, references: list[str]) -> dict:
    try:
        from bert_score import score as bs
        import torch
        P, R, F1 = bs([hypothesis]*len(references), references,
                      lang="en", verbose=False,
                      device="cuda" if torch.cuda.is_available() else "cpu")
        return {"precision": round(float(P.mean()),4),
                "recall":    round(float(R.mean()),4),
                "f1":        round(float(F1.mean()),4),
                "method":    "bertscore"}
    except ImportError:
        warnings.warn("bert-score not installed — using token overlap fallback")
        hyp  = set(hypothesis.lower().split())
        rows = []
        for ref in references:
            r = set(ref.lower().split())
            p = len(hyp & r)/len(hyp) if hyp else 0.0
            rc = len(hyp & r)/len(r)  if r   else 0.0
            f  = 2*p*rc/(p+rc)        if p+rc else 0.0
            rows.append((p, rc, f))
        if not rows:
            return {"precision":0.0,"recall":0.0,"f1":0.0,"method":"token_overlap_fallback"}
        return {"precision": round(sum(r[0] for r in rows)/len(rows),4),
                "recall":    round(sum(r[1] for r in rows)/len(rows),4),
                "f1":        round(sum(r[2] for r in rows)/len(rows),4),
                "method":    "token_overlap_fallback"}
 
 
def _groundedness_check(parsed: dict | None, chunks: list[dict]) -> dict:
    if not parsed:
        return {"status": "skipped", "reason": "no parsed output"}
    chunk_map = {c["citation_id"]: c["text"] for c in chunks}
    verdicts  = []
    for fact in parsed.get("key_facts", []):
        cid   = fact.get("citation_id", "")
        value = fact.get("value")
        claim = fact.get("claim", "")
        if cid not in chunk_map:
            verdicts.append({"claim":claim,"citation_id":cid,"value":value,
                             "verdict":"HALLUCINATED","reason":"citation_id not in retrieved chunks"})
            continue
        if value is None:
            verdicts.append({"claim":claim,"citation_id":cid,"value":value,
                             "verdict":"GROUNDED","reason":"null — no number to verify"})
            continue
        nums    = [float(n.replace(",","")) for n in re.findall(r"-?\d[\d,]*\.?\d*", chunk_map[cid])]
        tol     = abs(value)*0.01 if value != 0 else 0.01
        matched = any(abs(n-value) <= tol for n in nums)
        verdicts.append({"claim":claim,"citation_id":cid,"value":value,
                         "verdict":"GROUNDED" if matched else "UNVERIFIED",
                         "reason":"number found in source" if matched else "value not directly in chunk"})
    n = len(verdicts)
    return {
        "total_claims":      n,
        "grounded":          sum(1 for v in verdicts if v["verdict"]=="GROUNDED"),
        "unverified":        sum(1 for v in verdicts if v["verdict"]=="UNVERIFIED"),
        "hallucinated":      sum(1 for v in verdicts if v["verdict"]=="HALLUCINATED"),
        "groundedness_rate": round(sum(1 for v in verdicts if v["verdict"]=="GROUNDED")/n,4) if n else 1.0,
        "claim_verdicts":    verdicts,
    }
 
 
def _evaluate_generation(parsed: dict | None, chunks: list[dict]) -> dict:
    if not parsed:
        return {"bertscore": None, "groundedness": None}
    return {
        "bertscore":    _bertscore(parsed.get("answer_summary",""), [c["text"] for c in chunks]),
        "groundedness": _groundedness_check(parsed, chunks),
    }
 
 
# =============================================================================
# SECTION 9 — PERSISTENCE
# =============================================================================
 
def _qhash(query: str) -> str:
    return hashlib.md5(query.encode()).hexdigest()[:10]
 
 
def _save_retrieval_log(query, intent, resolved_tickers, raw, filtered, metrics) -> str:
    os.makedirs(RETRIEVAL_LOG_DIR, exist_ok=True)
    ts   = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    path = os.path.join(RETRIEVAL_LOG_DIR, f"retrieval_{ts}_{_qhash(query)}.json")
    with open(path,"w") as f:
        json.dump({
            "query":                query,
            "intent":               intent,
            "timestamp":            datetime.datetime.now().isoformat(),
            "resolved_tickers":     resolved_tickers,
            "top_k":                len(raw),
            "score_threshold":      RELEVANCE_THRESHOLD,
            "retrieval_metrics":    metrics,
            "chunks_before_filter": len(raw),
            "chunks_after_filter":  len(filtered),
            "retrieved_chunks":     filtered,
        }, f, indent=2, default=str)
    print(f"  💾 Retrieval log → {path}")
    return path
 
 
def _save_generation_log(query, gen, gen_eval, chunks, ret_log) -> str:
    os.makedirs(GENERATION_LOG_DIR, exist_ok=True)
    ts   = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    path = os.path.join(GENERATION_LOG_DIR, f"generation_{ts}_{_qhash(query)}.json")
    with open(path,"w") as f:
        json.dump({
            "query":              query,
            "timestamp":          datetime.datetime.now().isoformat(),
            "retrieval_log_path": ret_log,
            "generation":         gen,
            "evaluation":         gen_eval,
            "chunks_used": [
                {"citation_id": c.get("citation_id",""), "kb_source": c.get("kb_source",""),
                 "ticker": c.get("ticker",""), "source_url": c.get("source_url",""),
                 "score": c["score"]}
                for c in chunks
            ],
        }, f, indent=2, default=str)
    print(f"  💾 Generation log → {path}")
    return path
 
 
